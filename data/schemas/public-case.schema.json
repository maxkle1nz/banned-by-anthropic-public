  "title": "PublicCase",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "githubLogin": { "type": "string" },
    "displayName": { "type": "string" },
    "country": { "type": "string" },
    "role": { "type": "string" },
    "accessStatus": { "type": "string" },
    "projectName": { "type": "string" },
    "impactSummary": { "type": "string" },
    "updatedAt": { "type": "string" }
